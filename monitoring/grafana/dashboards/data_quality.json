        "targets": [
          {
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "expr": "sum(rate(ude_quarantine_total{tenant=\"$namespace\"}[5m])) by (pipeline) / sum(rate(ude_batch_records_processed_total{tenant=\"$namespace\"}[5m])) by (pipeline)",
