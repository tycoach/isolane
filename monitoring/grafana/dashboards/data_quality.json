        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "id": 1,
        "targets": [
          {
            "datasource": {"type": "prometheus", "uid": "prometheus"},
            "expr": "sum(rate(ude_quarantine_total{tenant=\"$namespace\"}[5m])) by (pipeline)",
            "legendFormat": "{{pipeline}}",
            "refId": "A"
          }
        ],
        "title": "Quarantine Rate / sec by Pipeline",
        "type": "timeseries"
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "fieldConfig": {
          "defaults": {"color": {"mode": "palette-classic"}, "unit": "percentunit"},
