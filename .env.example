# ─────────────────────────────────────────────────────────────────
# isolane — environment configuration
# cp .env.example .env  then fill in real values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=mtpif
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mtpif
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────
REDIS_HOST=redis-master
REDIS_PORT=6379
REDIS_SENTINEL_ADDRS=redis-sentinel:26379
REDIS_MASTER_NAME=mtpif-master

# ── Kafka ─────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=kafka:29092

# ── JWT keys (generated by: make keys) ───────────────────────────
# Paths inside the API container — do not change these
JWT_PRIVATE_KEY_PATH=/run/secrets/private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/public.pem

# ── Grafana ───────────────────────────────────────────────────────
GRAFANA_PASSWORD=change_me_dev
GRAFANA_URL=http://grafana:3000
GRAFANA_USER=admin

# ── Prometheus ────────────────────────────────────────────────────
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_SCRAPE_DIR=./monitoring/prometheus/scrape_configs

# ── API ───────────────────────────────────────────────────────────
ENV=development
APP_VERSION=dev
PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# ── Worker ────────────────────────────────────────────────────────
WORKER_HOST=engine-worker
WORKER_METRICS_PORT=9090
WORKER_COUNT=8
WORKER_LOG_LEVEL=info
ROCKSDB_PATH=./data/rocksdb

# ── Provisioner ───────────────────────────────────────────────────
TENANT_ROLE_PASSWORD=admin_dev
